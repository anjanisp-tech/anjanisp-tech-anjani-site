{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "anjanipandey.com"
        }
      ],
      "destination": "https://www.anjanipandey.com/$1",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/writing",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/api/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/os",
      "destination": "/os/index.html"
    },
    {
      "source": "/os/",
      "destination": "/os/index.html"
    },
    {
      "source": "/((?!api/|os(/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
