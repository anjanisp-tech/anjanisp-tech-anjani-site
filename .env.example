# ============================================================
# anjanipandey.com - Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Required ---

# Admin panel password (used for /admin login)
ADMIN_PASSWORD=

# Gemini AI API key (for chatbot and SEO executor)
# Accepts either name; GEMINI_API_KEY is preferred
GEMINI_API_KEY=
# GOOGLE_API_KEY=              # fallback alias

# --- Database ---

# Vercel Postgres connection string (production)
# If missing, falls back to local SQLite (ephemeral on Vercel)
POSTGRES_URL=

# --- Email Notifications (Resend) ---

# Resend API key for transactional emails (lead alerts, test emails)
RESEND_API_KEY=

# Recipient for notification emails (defaults to anjanisp@gmail.com)
# RESEND_TO_EMAIL=

# Sender address (defaults to onboarding@resend.dev on free tier)
# RESEND_FROM_EMAIL=

# --- Google Drive Integration ---

# Service account credentials for Knowledge Base sync and SEO pipeline
# 1. Create a Service Account in Google Cloud Console
# 2. Download the JSON key file
# 3. Copy client_email and private_key values here
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# EMAIL=                       # fallback alias

# The private key should be the full string including \n characters
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# KEY=                         # fallback alias

# Google Drive file ID for chatbot knowledge base document
# Can also be set via Admin > Knowledge tab in the dashboard
# GOOGLE_DRIVE_KNOWLEDGE_FILE_ID=
# DOC_ID=                      # fallback alias

# Google Drive folder ID for SEO instruction pipeline
# Can also be set via Admin > SEO Pipeline tab
# GOOGLE_DRIVE_SEO_FOLDER_ID=

# --- Optional / Auto-detected ---

# Set by Vercel automatically; do not set manually
# VERCEL=
# VERCEL_URL=

# NODE_ENV=production          # set automatically in production
# DISABLE_HMR=true             # disable Vite HMR if needed
