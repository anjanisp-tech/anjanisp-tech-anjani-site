# .env.example

# Google Service Account Credentials (for Knowledge Base)
# 1. Create a Service Account in Google Cloud Console
# 2. Download the JSON key file
# 3. Copy the values from the JSON file here
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# The private key should be the full string including \n characters
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# The ID of the Google Doc or .docx file in Google Drive
GOOGLE_DRIVE_KNOWLEDGE_FILE_ID=
# The ID of the Google Drive folder for SEO instructions
GOOGLE_DRIVE_SEO_FOLDER_ID=

# Admin Dashboard Security
ADMIN_PASSWORD=admin123
VITE_ADMIN_PASSWORD=admin123

# Resend API Key (for email notifications)
RESEND_API_KEY=
# Optional: The email address to send from. Must be verified in Resend. 
# Defaults to 'onboarding@resend.dev' if not provided.
RESEND_FROM_EMAIL=
# Optional: The email address to receive notifications.
RESEND_TO_EMAIL=anjanisp@gmail.com

# Vercel Postgres (Automatically provided when connected)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
